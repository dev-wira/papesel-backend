# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string

# ── Auth ──────────────────────────────────────────────────
MY_JWT_SECRET=replace_with_a_long_random_secret

# ── Redis (Upstash) — used for OTP storage + cooldowns ────
UPSTASH_REDIS_URL=rediss://your_upstash_redis_url
UPSTASH_REDIS_TOKEN=your_upstash_redis_token

# ── Email (used for OTP, invite, and reset-password mails) ─
# Fill in whichever mail provider utils/emailOptions.js is configured for
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
