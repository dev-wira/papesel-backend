# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string

# ── Auth ──────────────────────────────────────────────────
MY_JWT_SECRET=replace_with_a_long_random_secret

# ── Redis (Upstash) — used for OTP storage + cooldowns ────
UPSTASH_REDIS_URL=rediss://your_upstash_redis_url
UPSTASH_REDIS_TOKEN=your_upstash_redis_token

# ── Email (used for OTP, invite, and reset-password mails) ─
# Fill in whichever mail provider utils/emailOptions.js is configured for ( use only if you are using gmail SMTP services)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=

# The app uses Brevo Rest API for mail delivery..grab one from brevo.com and use like this 
BREVO_API_KEY=your_brevo_api-key
